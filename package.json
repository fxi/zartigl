{
  "name": "@fxi/zartigl",
  "version": "0.1.4",
  "description": "MapLibre GL JS plugin for animated particle flow from Zarr ocean current data",
  "type": "module",
  "main": "./dist/zartigl.js",
  "module": "./dist/zartigl.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/zartigl.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:mapbox": "vite --config vite.config.demo-mapbox.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "build": "vite build",
    "build:mapbox": "vite build --config vite.config.demo-mapbox.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "catalog": "cd scripts && uv run build_catalog.py",
    "smoke:sample": "npm run build:lib && node scripts/smoke-sample-point.mjs",
    "release:check": "npm run test && npm run build && npm run build:lib && npm run smoke:sample",
    "prepublishOnly": "npm run build:lib"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "maplibre",
    "zarr",
    "particles",
    "webgl",
    "ocean",
    "currents"
  ],
  "author": "fxi",
  "license": "MIT",
  "peerDependencies": {
    "maplibre-gl": ">=4.0.0"
  },
  "devDependencies": {
    "@tweakpane/core": "^2.0.5",
    "@types/d3": "^7.4.3",
    "@types/pako": "^2.0.4",
    "d3": "^7.9.0",
    "mapbox-gl": "^2.15.0",
    "maplibre-gl": "^5.17.0",
    "numcodecs": "^0.3.2",
    "pako": "^2.1.0",
    "tweakpane": "^4.0.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-glsl": "^1.5.5",
    "vitest": "^4.1.7"
  }
}
