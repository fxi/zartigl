{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Zartigl Catalog",
  "type": "object",
  "required": ["schemaVersion", "layers"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/Layer" },
      "minItems": 1
    }
  },
  "$defs": {
    "Layer": {
      "type": "object",
      "required": ["id", "label", "category", "kind", "dataset", "stores", "variables"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "category": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "kind": { "type": "string", "enum": ["vector", "scalar"] },
        "dataset": { "$ref": "#/$defs/Dataset" },
        "stores": { "$ref": "#/$defs/Stores" },
        "variables": { "$ref": "#/$defs/Variables" },
        "defaults": { "$ref": "#/$defs/Defaults" }
      }
    },
    "Dataset": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "productId": { "type": "string", "minLength": 1 }
      }
    },
    "Stores": {
      "type": "object",
      "required": ["field"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "object",
          "required": ["url"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "pattern": "^https?://" }
          }
        },
        "pointSeries": {
          "type": "object",
          "required": ["url"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "pattern": "^https?://" }
          }
        },
        "wmts": { "$ref": "#/$defs/Wmts" }
      }
    },
    "Variables": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "scalar" },
            "value": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "vector" },
            "u": { "type": "string", "minLength": 1 },
            "v": { "type": "string", "minLength": 1 },
            "derivation": { "$ref": "#/$defs/VectorDerivation" }
          },
          "oneOf": [
            { "required": ["u", "v"] },
            { "required": ["derivation"] }
          ]
        }
      ]
    },
    "VectorDerivation": {
      "type": "object",
      "required": ["kind", "direction_variable", "magnitude_variable", "direction_convention", "output_direction"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["direction_magnitude"] },
        "direction_variable": { "type": "string", "minLength": 1 },
        "magnitude_variable": { "type": "string", "minLength": 1 },
        "direction_convention": { "type": "string", "enum": ["from", "toward"] },
        "output_direction": { "type": "string", "enum": ["from", "toward"] }
      }
    },
    "Wmts": {
      "type": "object",
      "required": ["capabilities_url", "base_url", "layer", "tileMatrixSet", "format"],
      "additionalProperties": false,
      "properties": {
        "capabilities_url": { "type": "string", "pattern": "^https?://" },
        "base_url": { "type": "string", "pattern": "^https?://" },
        "layer": { "type": "string", "minLength": 1 },
        "tileMatrixSet": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 }
      }
    },
    "Defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string", "enum": ["zarr", "wmts"] },
        "palette": { "type": "string" },
        "particles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "density": { "type": "number", "exclusiveMinimum": 0 },
            "speed": { "type": "number", "exclusiveMinimum": 0 },
            "fade": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "raster": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
            "logScale": { "type": "boolean" },
            "vibrance": { "type": "number", "minimum": -1, "maximum": 1 }
          }
        }
      }
    }
  }
}
